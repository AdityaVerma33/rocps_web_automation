<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Functional_Test_Suite" verbose="2" annotations="JDK" configfailurepolicy="skip">
	<!-- Test suite for Agent functional testing -->
	<listeners>
		<listener class-name="com.subex.automation.helpers.TestNG.CustomTestListenerAdapter" />
	</listeners>

	<!-- Required parameters for framework initialization -->
	<parameter name="config" value="psconfig.properties"></parameter>
	<parameter name="orFiles" value="PS_OR.properties,Tariff_OR.properties,OR.properties"></parameter>

	<test name="Functional Tests" preserve-order="true">
		<classes>
			<class name="com.subex.rocps.automation.testcases.functionaltesting.TCRateSheetTemplate">
				<methods>
					<include name="rateSheetTemplateConfigDest" />
				</methods>
			</class>
		</classes>
	</test>
</suite>
